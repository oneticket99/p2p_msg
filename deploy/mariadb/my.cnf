# TooTalk MariaDB 설정 — Phase 4 docker stack 의 /etc/mysql/conf.d/tootalk.cnf mount.
# 한글 주석: utf8mb4 (이모지 + 한글 BMP/supplementary plane) + max_connections + KST timezone.

[mysqld]
# Charset + collation — 한글 + 이모지 정합
character-set-server = utf8mb4
collation-server = utf8mb4_unicode_ci
init-connect = 'SET NAMES utf8mb4'
skip-character-set-client-handshake

# Timezone — KST (Asia/Seoul) 일관성 의무 ([[feedback-timezone-kst]])
default-time-zone = '+09:00'

# Connection cap — Phase 4 production 진입 prepare
max_connections = 200
wait_timeout = 28800
interactive_timeout = 28800

# InnoDB tuning — 본 데모 서버 의 modest 4GB RAM 가정
innodb_buffer_pool_size = 1G
innodb_log_file_size = 256M
innodb_flush_log_at_trx_commit = 1
innodb_flush_method = O_DIRECT
innodb_file_per_table = 1

# Slow query log — 1초 초과 query 추적 (Phase 4 logging 정합)
slow_query_log = 1
slow_query_log_file = /var/log/mysql/slow.log
long_query_time = 1.0

# Binary log — Point-in-time recovery 의무 (production 진입 시점)
log_bin = mysql-bin
binlog_format = ROW
expire_logs_days = 7

# Security — local socket 외 의 root 차단
skip_name_resolve

[client]
default-character-set = utf8mb4
