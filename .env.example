# SPDX-License-Identifier: GPL-3.0-or-later
# TooTalk(p2p_msg) 환경 변수 sample — Phase 4 .env 통합 정합 (Item 2).
# 본 파일 = .env / .env.local / .env.production 의 의무 키 source of truth.
# 보안 의무 — 본 파일 외 .env* = git ignore. 실 값 입력 절대 commit 금지.

# ─── 1. 환경 식별 (필수) ─────────────────────────────────────────────────
ENV=local
# 가능 값: local / staging / production
# server.main 의 Config 클래스 분기 base.

LOG_LEVEL=INFO
LOG_FORMAT=text
# production = json + LOG_LEVEL=INFO 강제 (Item 4 정합).

TZ=Asia/Seoul
# 의무 — [[feedback-timezone-kst]] 정합.

# ─── 2. MariaDB (필수) ────────────────────────────────────────────────────
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=tootalk
DB_PASSWORD=
DB_NAME=tootalk
DB_POOL_SIZE=10
DB_POOL_RECYCLE_SECONDS=3600

# Docker compose MariaDB env (production 컨테이너 environment 동기)
MARIADB_ROOT_PASSWORD=
MARIADB_DATABASE=tootalk
MARIADB_USER=tootalk
MARIADB_PASSWORD=

# ─── 3. SMTP (필수 — OTP 발송) ────────────────────────────────────────────
SMTP_HOST=127.0.0.1
SMTP_PORT=1587
# local = 127.0.0.1:1587 (postfix container override port)
# production = postfix (docker-compose internal hostname)
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_ADDRESS=noreply@tootalk.demo
SMTP_DOMAIN=tootalk.demo
DKIM_SELECTOR=tootalk

# ─── 4. 시그널링 (필수) ──────────────────────────────────────────────────
SIGNAL_SERVER_HOST=0.0.0.0
SIGNAL_SERVER_WS_PORT=8765
SIGNAL_SERVER_WS_SCHEME=ws
SIGNAL_SERVER_MODE=ws
# Docker compose web (REST) + ws (signaling) 분기 base.

# ─── 5. STUN / TURN (필수 — WebRTC NAT 탐색) ──────────────────────────────
STUN_URL=stun:stun.l.google.com:19302
TURN_URL=
TURN_USERNAME=
TURN_CREDENTIAL=

# ─── 6. 클라이언트 (개발용) ──────────────────────────────────────────────
USER_NICKNAME=guest

# ─── 7. 봇 framework (선택, Phase 3) ─────────────────────────────────────
BOT_ENABLED=0
BOT_RATE_PER_MINUTE=20
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
# 본 키 = 평문 commit 절대 금지. .env.production secrets management 또는
# Docker secret file:// reference 권장.

# ─── 8. Firebase FCM push (선택, Phase 4 cycle 103~104) ──────────────────
FCM_PROJECT_ID=
FCM_CREDENTIAL_PATH=/run/secrets/fcm_service_account.json
# service-account.json = deploy/secrets/ 디렉토리 + chmod 600 의무.

# ─── 9. nginx / TLS (production) ─────────────────────────────────────────
ACME_EMAIL=admin@tootalk.demo
TLS_PRIMARY_DOMAIN=tootalk.demo
# Let's Encrypt certbot webroot challenge 정합.

# ─── 10. 외부 통합 (선택) ────────────────────────────────────────────────
TOONATION_API_BASE=https://api.toonation.com
TOONATION_API_KEY=
# Phase 3 default 고객센터 봇 의 Toonation 직접 통합 (옵션 B).

# ─── 11. 미디어 캐시 ─────────────────────────────────────────────────────
MEDIA_CACHE_DIR=./media_cache
