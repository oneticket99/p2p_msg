# p2p_msg 측 환경변수 예시 — 실제 값 측 .env.local 측 분리 측 .gitignore

# 시그널링 서버
SIGNAL_SERVER_HOST=114.207.112.73
SIGNAL_SERVER_WS_PORT=8765
SIGNAL_SERVER_WS_SCHEME=ws

# STUN / TURN
STUN_URL=stun:stun.l.google.com:19302
TURN_URL=
TURN_USERNAME=
TURN_CREDENTIAL=

# 클라이언트 측 사용자 식별 (개발용 — 정식 측 키 페어 측 대체)
USER_NICKNAME=guest

# 로그 레벨
LOG_LEVEL=INFO

# MariaDB 접속 (사용자 directive 2026-05-17 — 영속화 DB)
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=tootalk
DB_PASS=
DB_NAME=tootalk

# 미디어 캐시
MEDIA_CACHE_DIR=./media_cache
